<?xml version="1.0"?>
<ruleset name="SRCE ruleset">

    <config name="show_progress" value="1"/>
    <config name="ignore_warnings_on_exit" value="0"/>

    <file>src</file>
    <file>tests</file>
    <file>views</file>
    <file>heartphrame-manifest.php</file>

    <!-- This is the rule we inherit from. If you want to exclude some specific rules, see the docs on how to do that -->
    <rule ref="PSR12"/>

    <rule ref="Generic.WhiteSpace.ScopeIndent">
        <properties>
            <property name="exact" value="true" />
        </properties>
    </rule>

    <rule ref="Squiz.NamingConventions.ValidVariableName.NotCamelCaps"/>

    <!-- Only allow shorthand array syntax -->
    <rule ref="Generic.Arrays.DisallowLongArraySyntax" />

    <!-- Require the file to start with a declare(strict_types=1); -->
    <rule ref="Generic.PHP.RequireStrictTypes" />

    <!-- Do not allow unnecessary spaces inside arbitrary parentheses -->
    <rule ref="Generic.WhiteSpace.ArbitraryParenthesesSpacing" />

    <config name="installed_paths" value="vendor/slevomat/coding-standard"/>

    <!-- Do not allow any unused use-statements to exist -->
    <rule ref="SlevomatCodingStandard.Namespaces.UnusedUses" />

    <!-- Enforce alphabetically sorted use-statements -->
    <rule ref="SlevomatCodingStandard.Namespaces.AlphabeticallySortedUses" />

    <!-- Enforce the use of trailing commas -->
    <rule ref="SlevomatCodingStandard.Arrays.TrailingArrayComma" />
    <rule ref="SlevomatCodingStandard.Functions.RequireTrailingCommaInCall" />
    <rule ref="SlevomatCodingStandard.Functions.RequireTrailingCommaInClosureUse" />
    <rule ref="SlevomatCodingStandard.Functions.RequireTrailingCommaInDeclaration" />
</ruleset>

