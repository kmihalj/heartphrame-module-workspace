{
    "name": "aaieduhr/heartphrame-module-workspace",
    "description": "Workspace and hierarchical content organization module for HeartPhrame",
    "type": "heartphrame-module",
    "minimum-stability": "stable",
    "license": "EUPL-1.2",
    "repositories": [
        {
            "type": "vcs",
            "url": "https://gitlab.opencode.hr/srce/aai-eduhr/heartphrame/heartphrame-framework.git"
        },
        {
            "type": "vcs",
            "url": "https://gitlab.opencode.hr/srce/aai-eduhr/heartphrame/heartphrame-module-auth.git"
        },
        {
            "type": "vcs",
            "url": "https://gitlab.opencode.hr/srce/aai-eduhr/heartphrame/heartphrame-module-orm.git"
        }
    ],
    "require": {
        "php": ">=8.2",
        "aaieduhr/heartphrame-framework": "^0 || dev-main || dev-feature/orm-v2-foundation",
        "aaieduhr/heartphrame-module-auth": "^1.1",
        "aaieduhr/heartphrame-module-orm": "^1.1.2"
    },
    "suggest": {
        "aaieduhr/heartphrame-module-editor-html": "Enables Workspace-owned HTML pages and editing.",
        "aaieduhr/heartphrame-module-menu": "Adds Workspace entries to the application and settings menus.",
        "aaieduhr/heartphrame-module-notification": "Notifies publishers about review requests and authors about publication.",
        "aaieduhr/heartphrame-module-email": "Sends optional e-mail copies through the Notification module."
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^10 || ^11",
        "rector/rector": "^2.0",
        "squizlabs/php_codesniffer": "^3",
        "slevomat/coding-standard": "^8"
    },
    "autoload": {
        "psr-4": {
            "AaiEduHr\\HeartPhrameModuleWorkspace\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AaiEduHr\\HeartPhrameModuleWorkspace\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Srce",
            "email": "aai@srce.hr"
        }
    ],
    "config": {
        "sort-packages": true,
        "cache-dir": "build/composer",
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true
        },
        "optimize-autoloader": true,
        "composer-runtime-api": "^2.1"
    },
    "scripts": {
        "pre-commit": [
            "vendor/bin/phpcbf",
            "vendor/bin/rector --clear-cache",
            "vendor/bin/phpcs -p",
            "vendor/bin/phpstan --memory-limit=1024M",
            "vendor/bin/phpstan analyze -c phpstan-dev.neon --memory-limit=1024M",
            "vendor/bin/phpunit"
        ],
        "on-commit": [
            "vendor/bin/phpcs -p",
            "vendor/bin/rector --dry-run --clear-cache",
            "vendor/bin/phpstan --memory-limit=1024M",
            "vendor/bin/phpstan analyze -c phpstan-dev.neon --memory-limit=1024M",
            "vendor/bin/phpunit"
        ]
    }
}
